{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Quest Studies app.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "Mission": {
      "title": "Mission",
      "description": "A daily study task.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "time": { "type": "string" },
        "completed": { "type": "boolean" },
        "date": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "time", "completed", "date", "createdAt"]
    },
    "Simulado": {
      "title": "Simulado",
      "description": "A mock exam result.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "score": { "type": "number" },
        "targetScore": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "score", "targetScore", "date", "createdAt"]
    },
    "Redacao": {
      "title": "Redacao",
      "description": "An essay entry.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "theme": { "type": "string" },
        "score": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "theme", "score", "date", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles."
    },
    "/missions/{missionId}": {
      "schema": { "$ref": "#/entities/Mission" },
      "description": "Daily missions."
    },
    "/simulados/{simuladoId}": {
      "schema": { "$ref": "#/entities/Simulado" },
      "description": "Mock exams history."
    },
    "/redacoes/{redacaoId}": {
      "schema": { "$ref": "#/entities/Redacao" },
      "description": "Essays history."
    }
  }
}
